{
  "crons": [
    {
      "path": "/api/cron/sync-tournaments?live=1",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/sync-tournaments",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/refresh-fields",
      "schedule": "0 */12 * * *"
    },
    {
      "path": "/api/cron/finalize-results",
      "schedule": "10 * * * *"
    },
    {
      "path": "/api/cron/finalize-grouped-pools",
      "schedule": "5 * * * 2-4"
    },
    {
      "path": "/api/cron/lock-pools",
      "schedule": "7 * * * *"
    },
    {
      "path": "/api/cron/archive-unpaid-pools",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/cron/send-notifications",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/cron/send-payment-reminders",
      "schedule": "0 17 * * *"
    }
  ]
}
